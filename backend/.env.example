# Keycloak — mesmo realm da plataforma Spring
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=login-integrado
KEYCLOAK_CLIENT_ID=cemos-auth-gateway
KEYCLOAK_CLIENT_SECRET=trocar-em-producao

# CORS — origens permitidas (Angular dev + produção)
CORS_ORIGIN=https://gkdevstudio.com,https://www.gkdevstudio.com,http://localhost:4200

# MongoDB — mesmo banco da plataforma Spring
MONGODB_URI=mongodb://gkdev:gkdev_secret@localhost:27017/gkdev?authSource=admin
